{
  "info": {
    "name": "Go Auth App",
    "_postman_id": "4c4e63c5-d2a7-4c2b-bc63-0e9b6c9d3f6f",
    "description": "Manual test collection for go-auth-app",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "device_id", "value": "web" },
    { "key": "user_email", "value": "tester@example.com" },
    { "key": "user_password", "value": "secret123" },
    { "key": "managed_user_id", "value": "1" },
    { "key": "managed_user_email", "value": "managed@example.com" },
    { "key": "managed_user_password", "value": "secret123" },
    { "key": "verify_token", "value": "" },
    { "key": "reset_token", "value": "" },
    { "key": "google_id_token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('response contains ok status', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('success');",
              "  pm.expect(json.data.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('register returns success', function () {",
                  "  pm.expect([200, 500]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tester\",\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "const data = json.data || {};",
                  "pm.test('login returns tokens', function () {",
                  "  pm.expect(data.access_token).to.be.a('string').and.not.empty;",
                  "  pm.expect(data.refresh_token).to.be.a('string').and.not.empty;",
                  "});",
                  "if (data.access_token) pm.environment.set('access_token', data.access_token);",
                  "if (data.refresh_token) pm.environment.set('refresh_token', data.refresh_token);",
                  "console.log('access_token set:', !!data.access_token);",
                  "console.log('refresh_token set:', !!data.refresh_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Device-ID", "value": "{{device_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('profile returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('profile contains email', function () {",
                  "  pm.expect(json.data.email).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/auth/profile"
          }
        },
        {
          "name": "Update Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('update profile returns success', function () {",
                  "  pm.expect([200, 400, 401]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
