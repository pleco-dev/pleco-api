            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tester Updated\"\n}"
            },
            "url": "{{base_url}}/auth/profile"
          }
        },
        {
          "name": "Change Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('change password returns known status', function () {",
