{
  "info": {
    "name": "Pleco Negative",
    "_postman_id": "5c3388dc-c4c3-49fb-af6a-4e2e6fb04030",
    "description": "Negative checks for pleco-api validation, auth, and authorization behavior",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const loginJson = pm.response.json();",
                  "const loginData = loginJson.data || {};",
                  "pm.test('admin login returns access token and refresh cookie', function () {",
                  "  pm.expect(loginData.access_token).to.be.a('string').and.not.empty;",
                  "  pm.expect(loginData.refresh_token).to.be.undefined;",
                  "  pm.expect(pm.response.headers.get('Set-Cookie') || '').to.include('pleco_refresh_token=');",
                  "});",
                  "pm.environment.set('access_token', loginData.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Device-ID",
                "value": "{{device_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Negative Cases",
      "item": [
