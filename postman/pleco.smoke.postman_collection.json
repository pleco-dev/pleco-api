  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const healthJson = pm.response.json();",
                  "pm.test('health status is ok', function () {",
                  "  pm.expect(healthJson.status).to.eql('success');",
                  "  pm.expect(healthJson.data.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          }
        },
