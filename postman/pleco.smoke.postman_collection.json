    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "const data = json.data || {};",
                  "pm.test('admin login returns access token and refresh cookie', function () {",
                  "  pm.expect(data.access_token).to.be.a('string').and.not.empty;",
                  "  pm.expect(data.refresh_token).to.be.undefined;",
                  "  pm.expect(pm.response.headers.get('Set-Cookie') || '').to.include('pleco_refresh_token=');",
                  "});",
                  "pm.environment.set('access_token', data.access_token);",
                  "console.log('access_token set:', !!data.access_token);",
                  "console.log('refresh cookie set:', !!(pm.response.headers.get('Set-Cookie') || '').includes('pleco_refresh_token='));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Device-ID",
                "value": "{{device_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('profile returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const profileJson = pm.response.json();",
                  "const profileData = profileJson.data || {};",
                  "pm.test('profile contains admin email', function () {",
                  "  pm.expect(profileData.email).to.eql(pm.environment.get('admin_email'));",
                  "});",
                  "pm.test('profile includes permissions array', function () {",
                  "  pm.expect(Array.isArray(profileData.permissions)).to.eql(true);",
                  "});",
                  "if (profileData.id) pm.environment.set('admin_user_id', String(profileData.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/auth/profile"
          }
        },
        {
